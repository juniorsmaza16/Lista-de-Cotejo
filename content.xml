                &lt;div&gt;&lt;div style="overflow-x: auto;"&gt;
&lt;h3&gt;Lista de Cotejo sobre la Exposición Oral&lt;/h3&gt;
&lt;!-- DATOS INFORMATIVOS --&gt;
&lt;table style="width: 100%; border-collapse: collapse; border: 2px solid #000; margin-bottom: 15px;"&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;strong&gt;Institución:&lt;/strong&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;strong&gt;Fecha:&lt;/strong&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;strong&gt;Estudiante:&lt;/strong&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;strong&gt;Curso:&lt;/strong&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;&lt;strong&gt;Tema:&lt;/strong&gt;&lt;/td&gt;
&lt;td colspan="3" style="border: 2px solid #000; padding: 8px;"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;!-- LISTA DE COTEJO --&gt;
&lt;table style="width: 100%; border-collapse: collapse; border: 2px solid #000;"&gt;
&lt;thead&gt;
&lt;tr&gt;
&lt;th style="border: 2px solid #000; padding: 8px;"&gt;Indicadores&lt;/th&gt;
&lt;th style="border: 2px solid #000; padding: 8px;"&gt;Cumple&lt;/th&gt;
&lt;th style="border: 2px solid #000; padding: 8px;"&gt;No cumple&lt;/th&gt;
&lt;/tr&gt;
&lt;/thead&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;1. Saluda e introduce el tema con claridad al inicio de la exposición.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i1" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i1" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;2. Presenta los objetivos o propósito de la exposición.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i2" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i2" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;3. Utiliza un lenguaje claro y preciso.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i3" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i3" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;4. Desarrolla el tema con coherencia y un orden lógico.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i4" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i4" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;5. Demuestra conocimiento y dominio del tema.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i5" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i5" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;6. Mantiene una pronunciación, entonación y volumen adecuado.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i6" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i6" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;7. Hace contacto visual con el público durante la exposición.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i7" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i7" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;8. Emplea recursos de apoyo visual como diapositivas, esquemas, etc.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i8" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i8" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;9. Responde con seguridad las preguntas del público.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i9" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i9" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;10. Presenta conclusiones claras y cierra la exposición de manera ordenada.&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i10" value="1"&gt;&lt;/td&gt;
&lt;td style="border: 2px solid #000; text-align: center;"&gt;&lt;input type="radio" name="i10" value="0"&gt;&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;br&gt;&lt;button type="button" onclick="calificarListaCotejo()" style="padding: 8px 15px;"&gt; Calificar &lt;/button&gt;
&lt;div id="resultado" style="margin-top: 15px; padding: 10px; border: 2px solid #000;"&gt;&lt;/div&gt;
&lt;br&gt;
&lt;table style="width: 40%; border-collapse: collapse; border: 2px solid #000;"&gt;
&lt;tbody&gt;
&lt;tr&gt;
&lt;th style="border: 2px solid #000; padding: 8px;"&gt;Valoración&lt;/th&gt;
&lt;th style="border: 2px solid #000; padding: 8px;"&gt;Nivel&lt;/th&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;9 - 10&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;Excelente&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;7 - 8&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;Bueno&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;5 - 6&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;Regular&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;0 - 4&lt;/td&gt;
&lt;td style="border: 2px solid #000; padding: 8px;"&gt;Insuficiente&lt;/td&gt;
&lt;/tr&gt;
&lt;/tbody&gt;
&lt;/table&gt;
&lt;/div&gt;
&lt;script&gt;
function calificarListaCotejo() {

let total = 0;

for(let i = 1; i &lt;= 10; i++) {

let opcion = document.querySelector('input[name="i' + i + '"]:checked');

if(opcion === null) {
document.getElementById("resultado").innerHTML =
"&lt;strong&gt;Debe seleccionar una opción en todos los indicadores.&lt;/strong&gt;";
return;
}

total += Number(opcion.value);
}

let nivel = "";

if(total &gt;= 9){
nivel = "Excelente";
}
else if(total &gt;= 7){
nivel = "Bueno";
}
else if(total &gt;= 5){
nivel = "Regular";
}
else{
nivel = "Insuficiente";
}

document.getElementById("resultado").innerHTML =
"&lt;strong&gt;Indicadores cumplidos:&lt;/strong&gt; " + total + " de 10&lt;br&gt;&lt;br&gt;" +
"&lt;strong&gt;Calificación final:&lt;/strong&gt; " + total.toFixed(2) + " / 10&lt;br&gt;&lt;br&gt;" +
"&lt;strong&gt;Nivel de desempeño:&lt;/strong&gt; " + nivel;
}
&lt;/script&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
